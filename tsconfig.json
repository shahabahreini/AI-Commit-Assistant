{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022", "DOM"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"jsx": "react",
		"skipLibCheck": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": true
	},
	"exclude": [
		"node_modules/@types/mdx"
	]
}
